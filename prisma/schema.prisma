generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  PATRON
  SECRETAIRE
  EMPLOYE
}

enum DevisStatus {
  BROUILLON
  ENVOYE
  ACCEPTE
  REFUSE
  FACTURE
}

model Company {
  id         String  @id @default(cuid())
  name       String
  email      String
  phone      String?
  address    String?
  city       String?
  postalCode String?
  siret      String?
  logoUrl        String?
  primaryColor   String?
  tauxHoraire    Float    @default(45)
  metier         String   @default("multi-services")
  relancesActive Boolean  @default(true)
  relancesJours  Int[]    @default([7, 14, 30])
  devisRelancesActive  Boolean @default(true)
  devisRelancesJours   Int[]   @default([3, 7, 14])

  // Legal / fiscal fields
  tvaIntra              String?
  formeJuridique        String?
  capitalSocial         String?
  codeAPE               String?
  rcs                   String?

  // Assurance decennale
  assuranceDecennaleNom    String?
  assuranceDecennaleNumero String?
  assuranceDecennaleZone   String?

  // Default legal conditions
  conditionsGeneralesDevis String?
  delaiPaiementJours       Int     @default(30)

  // Free trial
  trialEndsAt                DateTime?

  // Stripe subscription
  stripeCustomerId           String?   @unique
  stripeSubscriptionId       String?   @unique
  stripePriceId              String?
  subscriptionStatus         String    @default("inactive") // active, trialing, past_due, canceled, incomplete, inactive
  subscriptionCurrentPeriodEnd DateTime?

  isDemo         Boolean   @default(false)
  demoExpiresAt  DateTime?

  // Affiliate program
  affiliateCode          String?   @unique
  affiliateReferredById  String?   // Company ID that referred this company
  affiliateBalance       Float     @default(0) // Available balance in euros
  iban                   String?   // IBAN for affiliate payouts

  // Stripe Connect (affiliate payouts)
  stripeConnectAccountId  String?   @unique
  stripeConnectOnboarded  Boolean   @default(false)

  users          User[]
  clients        Client[]
  interventions  Intervention[]
  feuillesHeures FeuilleHeure[]
  plannings      Planning[]
  notifications  Notification[]
  devis          Devis[]
  factures       Facture[]
  relances       Relance[]
  relancesDevis  RelanceDevis[]
  prestations    Prestation[]
  articles       ArticleCatalogue[]
  demandesConges DemandeConge[]
  supportTickets SupportTicket[]
  affiliateEarnings  AffiliateCommission[] @relation("affiliateEarnings")
  affiliateSource    AffiliateCommission[] @relation("affiliateSource")

  // Ambassador program
  ambassadorReferredById String?
  ambassadorReferredBy   Ambassador? @relation("ambassadorReferrals", fields: [ambassadorReferredById], references: [id])
  ambassadorCommissions  AmbassadorCommission[] @relation("ambassadorCommissionSource")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("companies")
}

model User {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String
  firstName    String
  lastName     String
  role         Role   @default(EMPLOYE)
  permissions  String[] @default([])

  emailVerified              Boolean   @default(false)
  emailVerifyToken           String?   @unique
  emailVerifyTokenExpiresAt  DateTime?
  passwordResetToken         String?   @unique
  passwordResetTokenExpiresAt DateTime?

  referralCode     String?    @unique
  freeMonthsEarned Int        @default(0)

  companyId      String
  company        Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  interventions  Intervention[]
  assignedInterventions InterventionAssignment[]
  feuillesHeures FeuilleHeure[]
  feuillesValidees FeuilleHeure[] @relation("feuillesValidees")
  plannings      Planning[]
  notifications  Notification[]
  devis          Devis[]
  factures       Facture[]
  referralsMade     Referral[] @relation("referralsMade")
  referralsReceived Referral[] @relation("referralsReceived")
  congesDemandes    DemandeConge[] @relation("congesDemandes")
  congesValides     DemandeConge[] @relation("congesValides")
  pushSubscriptions PushSubscription[]
  refreshTokens     RefreshToken[]
  supportTickets    SupportTicket[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@map("users")
}

model Client {
  id         String  @id @default(cuid())
  firstName  String
  lastName   String
  email      String?
  phone      String?
  address    String?
  city       String?
  postalCode String?
  notes      String?

  companyId     String
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  interventions Intervention[]
  devis         Devis[]
  factures      Facture[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([lastName, firstName])
  @@map("clients")
}

model Intervention {
  id          String   @id @default(cuid())
  reference   String
  title       String
  description String?
  address     String?
  date        DateTime @default(now())
  status      String   @default("PENDING")
  amountHT    Float    @default(0)
  tvaRate     Float    @default(20)
  amountTTC   Float    @default(0)
  notes          String?
  heuresEstimees Float?
  coutMainOeuvre Float?

  clientId     String
  client       Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdById  String
  createdBy    User    @relation(fields: [createdById], references: [id])
  companyId    String
  company      Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  devisId      String?
  devis        Devis?  @relation(fields: [devisId], references: [id])

  signatureClient            String?
  signedAt                   DateTime?
  signatureToken             String?   @unique
  signatureTokenExpiresAt    DateTime?

  items            InterventionItem[]
  photos           InterventionPhoto[]
  feuillesHeures   FeuilleHeure[]
  plannings        Planning[]
  factures         Facture[]
  materiels        MaterielUtilise[]
  assignedUsers    InterventionAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([clientId])
  @@index([createdById])
  @@index([status])
  @@index([date])
  @@index([companyId, status, date])
  @@index([devisId])
  @@map("interventions")
}

model InterventionItem {
  id          String @id @default(cuid())
  description String
  quantity    Float  @default(1)
  unitPrice   Float  @default(0)
  total       Float  @default(0)
  type        String @default("prestation") // prestation, main_oeuvre, materiel

  // Margin fields for materials
  prixAchat   Float?  // Purchase price (hidden from client)
  coefMarge   Float?  // Margin coefficient (e.g. 1.5 = 50% margin)

  interventionId String
  intervention   Intervention @relation(fields: [interventionId], references: [id], onDelete: Cascade)

  @@index([interventionId])
  @@map("intervention_items")
}

model FeuilleHeure {
  id                String   @id @default(cuid())
  date              DateTime
  heureDebut        String?
  heureFin          String?
  heuresTravaillees Float
  panierRepas       Boolean  @default(false)
  zone              Int?
  grandDeplacement  Boolean  @default(false)
  valide            Boolean  @default(false)

  // Validation avancée
  statut          String    @default("EN_ATTENTE") // EN_ATTENTE, VALIDEE, REFUSEE
  valideParId     String?
  validePar       User?     @relation("feuillesValidees", fields: [valideParId], references: [id])
  dateValidation  DateTime?
  motifRefus      String?

  utilisateurId  String
  utilisateur    User         @relation(fields: [utilisateurId], references: [id])
  interventionId String?
  intervention   Intervention? @relation(fields: [interventionId], references: [id])
  entrepriseId   String
  entreprise     Company      @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([entrepriseId])
  @@index([utilisateurId])
  @@index([entrepriseId, utilisateurId, date])
  @@index([entrepriseId, statut])
  @@map("feuilles_heures")
}

model InterventionAssignment {
  id String @id @default(cuid())

  interventionId String
  intervention   Intervention @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now())

  @@unique([interventionId, userId])
  @@index([interventionId])
  @@index([userId])
  @@map("intervention_assignments")
}

model Planning {
  id         String   @id @default(cuid())
  date       DateTime
  heureDebut DateTime
  heureFin   DateTime
  statut     String   @default("PREVU")

  utilisateurId  String
  utilisateur    User         @relation(fields: [utilisateurId], references: [id])
  interventionId String?
  intervention   Intervention? @relation(fields: [interventionId], references: [id])
  entrepriseId   String
  entreprise     Company      @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([entrepriseId])
  @@index([utilisateurId])
  @@index([entrepriseId, date])
  @@map("plannings")
}

model DemandeConge {
  id          String   @id @default(cuid())
  dateDebut   DateTime
  dateFin     DateTime
  type        String   // CONGE_PAYE, MALADIE, RTT, SANS_SOLDE
  commentaire String?
  statut      String   @default("EN_ATTENTE") // EN_ATTENTE, ACCEPTE, REFUSE
  reponse     String?  // commentaire du validateur

  demandeurId    String
  demandeur      User     @relation("congesDemandes", fields: [demandeurId], references: [id])
  validateurId   String?
  validateur     User?    @relation("congesValides", fields: [validateurId], references: [id])
  dateReponse    DateTime?
  entrepriseId   String
  entreprise     Company  @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([entrepriseId])
  @@index([demandeurId])
  @@index([entrepriseId, statut])
  @@index([entrepriseId, dateDebut, dateFin])
  @@map("demandes_conges")
}

model InterventionPhoto {
  id    String  @id @default(cuid())
  data  String
  label String?
  ordre Int     @default(0)

  interventionId String
  intervention   Intervention @relation(fields: [interventionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([interventionId])
  @@map("intervention_photos")
}

model Notification {
  id      String  @id @default(cuid())
  type    String
  message String
  lien    String?
  lu      Boolean @default(false)

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, lu])
  @@index([companyId])
  @@map("notifications")
}

model Devis {
  id                      String      @id @default(cuid())
  reference               String
  title                   String
  description             String?
  date                    DateTime    @default(now())
  dateExpiration          DateTime?
  status                  DevisStatus @default(BROUILLON)
  amountHT                Float       @default(0)
  tvaRate                 Float       @default(20)
  amountTTC               Float       @default(0)
  notes                   String?
  conditionsParticulieres String?

  // Adresse chantier (si différente du client)
  adresseChantier         String?
  villeChantier           String?
  cpChantier              String?

  // Conditions de paiement
  conditionsPaiement      String?
  acomptePercent          Float?
  delaiTravaux            String?

  // Acceptation client
  acceptToken             String?   @unique
  acceptTokenExpiresAt    DateTime?
  signatureClient         String?
  signedAt                DateTime?
  acceptedAt              DateTime?

  // Refus client
  motifRefus              String?
  refusedAt               DateTime?

  clientId    String
  client      Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User    @relation(fields: [createdById], references: [id])
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  items         DevisItem[]
  piecesJointes DevisPieceJointe[]
  facture       Facture?
  interventions Intervention[]
  relances      RelanceDevis[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([clientId])
  @@index([createdById])
  @@index([status])
  @@index([companyId, status, date])
  @@map("devis")
}

model DevisItem {
  id          String @id @default(cuid())
  description String
  quantity    Float  @default(1)
  unitPrice   Float  @default(0)
  total       Float  @default(0)
  type        String @default("prestation") // prestation, main_oeuvre, materiel

  // Margin fields for materials (hidden from client)
  prixAchat            Float?   // Purchase price
  coefMarge            Float?   // Margin coefficient (e.g. 1.5 = 50% margin)
  fournisseur          String?  // Supplier name
  referenceFournisseur String?  // Supplier reference

  devisId String
  devis   Devis  @relation(fields: [devisId], references: [id], onDelete: Cascade)

  @@index([devisId])
  @@map("devis_items")
}

model DevisPieceJointe {
  id        String @id @default(cuid())
  nom       String
  type      String // photo, plan, document
  data      String // base64 data
  taille    Int    @default(0) // bytes

  devisId   String
  devis     Devis  @relation(fields: [devisId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([devisId])
  @@map("devis_pieces_jointes")
}

model Facture {
  id                 String    @id @default(cuid())
  numero             String    @unique
  date               DateTime  @default(now())
  dateEcheance       DateTime?
  status             String    @default("EN_ATTENTE")
  amountHT           Float     @default(0)
  tvaRate            Float     @default(20)
  amountTTC          Float     @default(0)
  datePaiement       DateTime?
  modePaiement       String?
  conditionsPaiement String?
  mentionsLegales    String?
  notes              String?
  pdfSnapshot        String?
  factureAvoirId     String?
  viewToken          String?   @unique
  viewTokenExpiresAt DateTime?

  interventionId String?
  intervention   Intervention? @relation(fields: [interventionId], references: [id])
  devisId        String?       @unique
  devis          Devis?        @relation(fields: [devisId], references: [id])
  mentionDevis   String?
  clientId       String
  client         Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  companyId      String
  company        Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User          @relation(fields: [createdById], references: [id])

  items    FactureItem[]
  relances Relance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([clientId])
  @@index([status])
  @@index([companyId, status])
  @@index([companyId, status, dateEcheance])
  @@index([createdById])
  @@map("factures")
}

model FactureItem {
  id          String @id @default(cuid())
  description String
  quantity    Float  @default(1)
  unitPrice   Float  @default(0)
  total       Float  @default(0)
  type        String @default("prestation")

  // Material margin (artisan-only, never shown to client)
  prixAchat            Float?
  coefMarge            Float?
  fournisseur          String?
  referenceFournisseur String?

  factureId String
  facture   Facture @relation(fields: [factureId], references: [id], onDelete: Cascade)

  @@index([factureId])
  @@map("facture_items")
}

model MaterielUtilise {
  id             String @id @default(cuid())
  nom            String
  quantite       Float  @default(1)
  prixUnitaire   Float  @default(0)

  interventionId String
  intervention   Intervention @relation(fields: [interventionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([interventionId])
  @@map("materiels_utilises")
}

model ArticleCatalogue {
  id            String  @id @default(cuid())
  nom           String
  description   String?
  reference     String?
  categorie     String  @default("Général")
  unite         String  @default("pièce") // pièce, mètre, kg, litre, m²
  prixAchat     Float   @default(0)
  margePercent  Float   @default(0)
  prixVente     Float   @default(0) // calculé: prixAchat * (1 + margePercent/100)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([companyId, categorie])
  @@map("articles_catalogue")
}

model Relance {
  id        String   @id @default(cuid())
  numero    Int
  date      DateTime @default(now())

  factureId String
  facture   Facture @relation(fields: [factureId], references: [id], onDelete: Cascade)
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([factureId])
  @@index([companyId])
  @@map("relances")
}

model Prestation {
  id            String  @id @default(cuid())
  label         String
  description   String?
  category      String
  hours         Float
  prixMateriel  Float   @default(0)
  metier        String

  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([companyId, metier])
  @@map("prestations")
}

model RelanceDevis {
  id        String   @id @default(cuid())
  numero    Int
  date      DateTime @default(now())
  message   String?

  devisId   String
  devis     Devis    @relation(fields: [devisId], references: [id], onDelete: Cascade)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([devisId])
  @@index([companyId])
  @@map("relances_devis")
}

model PushSubscription {
  id       String @id @default(cuid())
  endpoint String
  p256dh   String
  auth     String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, endpoint])
  @@index([userId])
  @@map("push_subscriptions")
}

model Referral {
  id             String    @id @default(cuid())
  referrerUserId String
  referrerUser   User      @relation("referralsMade", fields: [referrerUserId], references: [id], onDelete: Cascade)
  referredUserId String
  referredUser   User      @relation("referralsReceived", fields: [referredUserId], references: [id], onDelete: Cascade)
  status         String    @default("PENDING") // PENDING, REWARDED
  rewardedAt     DateTime?
  createdAt      DateTime  @default(now())

  @@unique([referrerUserId, referredUserId])
  @@index([referrerUserId])
  @@map("referrals")
}

model SupportTicket {
  id          String   @id @default(cuid())
  subject     String
  category    String   @default("general") // general, bug, billing, feature, other
  status      String   @default("open")    // open, in_progress, resolved, closed
  priority    String   @default("normal")  // low, normal, high, urgent

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  messages    SupportMessage[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([userId])
  @@index([status])
  @@map("support_tickets")
}

model SupportMessage {
  id        String   @id @default(cuid())
  content   String
  isAdmin   Boolean  @default(false)
  authorName String?

  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([ticketId])
  @@map("support_messages")
}

model RateLimit {
  id        String   @id @default(cuid())
  key       String   @unique // e.g. "login:192.168.1.1" or "forgot:user@email.com"
  count     Int      @default(1)
  expiresAt DateTime

  @@index([expiresAt])
  @@map("rate_limits")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model AffiliateCommission {
  id                String   @id @default(cuid())
  affiliateCompanyId String  // The company that earns the commission
  referredCompanyId  String  // The company that was referred
  stripeInvoiceId    String? @unique // Stripe invoice that triggered this commission
  amount             Float   // Commission amount in euros
  commissionRate     Float   @default(0.15) // 15%
  invoiceAmount      Float   // Original invoice amount
  status             String  @default("pending") // pending, transferred, paid
  paidAt             DateTime?
  stripeTransferId   String?   // Stripe Transfer ID for Connect payouts

  affiliateCompany Company @relation("affiliateEarnings", fields: [affiliateCompanyId], references: [id], onDelete: Cascade)
  referredCompany  Company @relation("affiliateSource", fields: [referredCompanyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([affiliateCompanyId])
  @@index([referredCompanyId])
  @@index([status])
  @@map("affiliate_commissions")
}

// ── Ambassador Program ──────────────────────────────────

model Ambassador {
  id            String  @id @default(cuid())
  firstName     String
  lastName      String
  email         String  @unique
  phone         String?
  passwordHash  String
  affiliateCode String  @unique

  // Stripe Connect
  stripeConnectAccountId  String?  @unique
  stripeConnectOnboarded  Boolean  @default(false)

  // Earnings
  balance       Float   @default(0) // Available balance in euros

  // Tier override (null = auto-calculated from active referrals)
  customTier              String?  // bronze, argent, or, diamant
  customCommissionRate    Float?   // Override commission rate (e.g. 0.25)

  commissions    AmbassadorCommission[]
  rewards        MonthlyReward[]
  referredCompanies Company[] @relation("ambassadorReferrals")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ambassadors")
}

model AmbassadorCommission {
  id              String   @id @default(cuid())
  ambassadorId    String
  referredCompanyId String
  stripeInvoiceId String?  @unique
  amount          Float
  commissionRate  Float
  invoiceAmount   Float
  status          String   @default("pending") // pending, paid
  paidAt          DateTime?
  stripeTransferId String?

  ambassador      Ambassador @relation(fields: [ambassadorId], references: [id], onDelete: Cascade)
  referredCompany Company    @relation("ambassadorCommissionSource", fields: [referredCompanyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([ambassadorId])
  @@index([referredCompanyId])
  @@index([status])
  @@map("ambassador_commissions")
}

model MonthlyReward {
  id            String   @id @default(cuid())
  ambassadorId  String
  month         Int      // 1-12
  year          Int
  rank          Int      // 1, 2, 3
  amount        Float    // 100, 50, 25
  referralsCount Int     // number of referrals that month
  credited      Boolean  @default(false) // balance credited?
  creditedAt    DateTime?

  ambassador Ambassador @relation(fields: [ambassadorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([ambassadorId, month, year])
  @@index([month, year])
  @@map("monthly_rewards")
}
